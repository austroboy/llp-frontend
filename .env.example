# =============================================================================
# Labor Law Partner — Universe Platform
# Copy this file to `.env.local` and fill in the values from your providers.
# Do NOT commit `.env.local`. Variables prefixed with NEXT_PUBLIC_ are
# exposed to the browser bundle; everything else is server-only.
# =============================================================================

# --- Platform URLs --------------------------------------------------------
# In Vercel, NEXT_PUBLIC_VERCEL_URL and VERCEL_URL are set automatically.
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_SITE_URL=

# --- Supabase (Postgres + pgvector + storage) -----------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Convex (real-time backend) -------------------------------------------
NEXT_PUBLIC_CONVEX_URL=

# --- Clerk (authentication + webhooks) ------------------------------------
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- AI providers ---------------------------------------------------------
GEMINI_API_KEY=
GEMINI_AI_STUDIO_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# --- Inference proxy (RAG + tree-reasoning chat backend) ------------------
CHAT_PROXY_URL=
CHAT_PROXY_API_KEY=

# --- Agent orchestrator (background-task gateway) -------------------------
GOCLAW_URL=
GOCLAW_TOKEN=
GOCLAW_USER_ID=
GOCLAW_URL_VERIFY=
GOCLAW_URL_FOLLOWUP=
GOCLAW_URL_HELPERS=
GOCLAW_URL_RECOVER=

# --- Email (AWS SES + bounce/complaint webhooks) --------------------------
AWS_REGION=
SES_SNS_TOPIC_ARN=

# --- Rate limiting (Upstash Redis) ----------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Analytics (PostHog) --------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
POSTHOG_HOST_API=
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# --- Cloudflare (DNS / domain ops, optional) ------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# --- Telegram bridge (optional) -------------------------------------------
TELEGRAM_API_KEY=

# --- PDF rendering (headless Chromium) ------------------------------------
# In production (Vercel), use @sparticuz/chromium-min; locally, point to
# system Chromium for faster iteration. Both PATH vars are optional.
PUPPETEER_EXECUTABLE_PATH=
CHROMIUM_PATH=
PDF_LOCAL_RENDER=
PDF_NAV_TIMEOUT_MS=
PDF_RENDER_TIMEOUT_MS=

# --- Internal secrets (set to long random opaque strings) -----------------
# CRON_SECRET protects /api/cron/* from being hit by anyone but Vercel
# scheduler. NOTIFICATION_SECRET protects internal-fetch notification calls.
CRON_SECRET=
NOTIFICATION_SECRET=

# --- Verify pipeline ------------------------------------------------------
VERIFY_MODEL=opus
VERIFY_CORPUS_ROOT=

# --- Feature flags (leave blank or "0" to disable) ------------------------
ENABLE_HONESTY_GUARD=
ENABLE_RECOVERY_LOOP=
ENABLE_VERIFY_CACHE=
NEXT_PUBLIC_TEMPLATES_DISABLED=
